{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "reson-desktop",
  "version": "0.1.0",
  "identifier": "com.reson.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @reson/web dev:host",
    "beforeBuildCommand": "pnpm --filter @reson/web build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Reson",
        "width": 1280,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
